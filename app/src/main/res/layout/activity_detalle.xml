<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:fitsSystemWindows="true"
    android:background="#2C3E50"> <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Ficha del Juego"
    android:textSize="28sp"
    android:textStyle="bold"
    android:textColor="#ECF0F1"
    android:gravity="center"
    android:layout_marginBottom="24dp"
    android:layout_marginTop="16dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="#FFFFFF">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del juego"
                android:textColor="#7F8C8D"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etDetalleNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2C3E50"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Número de Jugadores (Ej: 2-4)"
                android:textColor="#7F8C8D"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etDetalleJugadores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2C3E50"
                android:textSize="20sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duración (minutos)"
                android:textColor="#7F8C8D"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etDetalleDuracion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2C3E50"
                android:textSize="20sp"
                android:inputType="number"
                android:layout_marginBottom="24dp"/>

            <Switch
                android:id="@+id/switchJugado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡Ya lo he jugado!"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2980B9"
                android:layout_marginBottom="32dp"
                android:thumbTint="@color/switch_colores"
                android:trackTint="@color/switch_colores"
                app:thumbTint="@color/switch_colores"
                app:trackTint="@color/switch_colores" />

            <Button
                android:id="@+id/btnGuardarCambios"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="GUARDAR CAMBIOS"
                android:backgroundTint="#27AE60"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivDetalleCaratula"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>